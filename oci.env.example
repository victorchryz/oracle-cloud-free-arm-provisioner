# Availability Domain (tenta todos automaticamente)
OCT_FREE_AD=AD-1,AD-2,AD-3

# Nome da instância
DISPLAY_NAME=minha-vps-arm

# Shape ARM (4 OCPU, 24GB RAM)
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex

# Segunda instância micro? (False = só quer 1 ARM)
SECOND_MICRO_INSTANCE=False

# Tempo entre tentativas por AD (segundos)
AD_WAIT_TIME_SECS=20

# Tempo entre ciclos completos (segundos)
REQUEST_WAIT_TIME_SECS=60

# Arquivos de configuração
OCI_CONFIG=/app/oci_config
SSH_PUBLIC_KEY_FILE=/app/ssh_public_key.pub

# Subnet e imagem automáticos
OCI_SUBNET_ID=
OCI_IMAGE_ID=

# Sistema operacional
OPERATING_SYSTEM=Canonical Ubuntu
OS_VERSION=24.04 Minimal aarch64

# IP público
ASSIGN_PUBLIC_IP=true

# Tamanho do disco (GB) - máximo 200 no free tier
BOOT_VOLUME_SIZE=200

# Telegram (configure se quiser notificações)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
